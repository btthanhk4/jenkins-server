// ============================================================================
// Pipeline mẫu - deploy 1 dự án bằng Docker.
// Copy nội dung này vào repo dự án của bạn với tên "Jenkinsfile".
// ============================================================================

pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        IMAGE = "registry.company.com/my-app"
        TAG   = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE:$TAG .'
            }
        }

        stage('Test') {
            steps {
                sh 'echo "chạy unit test ở đây"'
            }
        }

        stage('Security Scan') {
            steps {
                sh 'trivy image --exit-code 0 --severity HIGH,CRITICAL $IMAGE:$TAG'
            }
        }

        stage('Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'registry-credentials',
                    usernameVariable: 'REG_USER',
                    passwordVariable: 'REG_PASS')]) {
                    sh '''
                        echo "$REG_PASS" | docker login registry.company.com -u "$REG_USER" --password-stdin
                        docker push $IMAGE:$TAG
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    echo "Triển khai $IMAGE:$TAG ..."
                    # ví dụ: kubectl set image deployment/my-app my-app=$IMAGE:$TAG
                    # hoặc:  docker compose -f /srv/my-app/docker-compose.yml up -d
                '''
            }
        }
    }

    post {
        success { echo "✅ Deploy thành công build #${env.BUILD_NUMBER}" }
        failure { echo "❌ Build thất bại" }
        always  { cleanWs() }
    }
}
