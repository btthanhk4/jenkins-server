# ============================================================================
# Sao chép file này thành .env rồi điền giá trị thật:
#     cp .env.example .env
# LƯU Ý: file .env đã bị .gitignore -> KHÔNG bao giờ push secret lên GitHub.
# ============================================================================

# --- Thông tin admin khởi tạo ---
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=ChangeMe_StrongPassword_123!
JENKINS_ADMIN_EMAIL=devops@company.com

# --- URL truy cập Jenkins (đổi thành domain/IP thật của VM) ---
JENKINS_URL=http://192.168.10.185:8080/

# --- Cổng ---
JENKINS_HTTP_PORT=8080
JENKINS_AGENT_PORT=50000

# --- Múi giờ ---
TZ=Asia/Ho_Chi_Minh

# --- Nơi lưu dữ liệu Jenkins trên host (bind mount) ---
JENKINS_HOME_HOST=/data/jenkins_home

# --- Giới hạn RAM cho container Jenkins (JVM dùng ~70% số này) ---
JENKINS_MEM_LIMIT=4g

# --- GID của group 'docker' trên host, để jenkins dùng được docker.sock ---
# Lấy bằng: getent group docker | cut -d: -f3
DOCKER_GID=999

# --- (Tuỳ chọn) Credentials tích hợp GitLab/GitHub ---
# GITLAB_USER=
# GITLAB_TOKEN=
